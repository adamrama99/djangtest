# File ini opsional.
# Jika tidak dibuat, project tetap jalan dengan default SQLite di ./db.sqlite3.
# Untuk server PostgreSQL 12, pakai Django 4.2.x dan isi salah satu
# konfigurasi PostgreSQL di bawah ini.

DJANGO_SECRET_KEY=ganti-dengan-secret-key-yang-lebih-aman
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Pilih salah satu konfigurasi database:

# 1) Default SQLite
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# 2) PostgreSQL via DATABASE_URL
# Cocok untuk local dan server bila format URL lebih nyaman dikelola.
# DATABASE_URL=postgresql://postgres:password@localhost:5432/djangtest

# 3) PostgreSQL via variabel terpisah
DB_ENGINE=django.db.backends.postgresql
DB_NAME=djangtest
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# Jika ingin static / media tetap dilayani Django
DJANGO_SERVE_STATIC=True
DJANGO_SERVE_MEDIA=True
