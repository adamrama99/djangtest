# File ini opsional.
# Jika tidak dibuat, project tetap jalan dengan default:
# - database SQLite di ./db.sqlite3
# - ALLOWED_HOSTS = *
# - static dan media dilayani langsung oleh Django

DJANGO_SECRET_KEY=ganti-dengan-secret-key-yang-lebih-aman
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Pilih salah satu:

# 1) Default SQLite
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=db.sqlite3

# 2) Atau PostgreSQL / MySQL lewat URL
# DATABASE_URL=postgresql://postgres:password@localhost:5432/djangtest

# 3) Atau PostgreSQL / MySQL lewat variabel terpisah
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=djangtest
# DB_USER=postgres
# DB_PASSWORD=secret
# DB_HOST=localhost
# DB_PORT=5432

# Jika ingin static / media tidak dilayani Django, ubah ke False
# DJANGO_SERVE_STATIC=True
# DJANGO_SERVE_MEDIA=True
